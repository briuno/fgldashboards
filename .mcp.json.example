{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=ifjpzyqjdagnxygbkwpm"
    },
    "hostinger-hosting": {
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-hosting-mcp"],
      "env": { "HOSTINGER_API_TOKEN": "cole_aqui_o_token_da_hostinger" }
    },
    "hostinger-domains": {
      "command": "npx.cmd",
      "args": ["--package=hostinger-api-mcp@latest", "hostinger-domains-mcp"],
